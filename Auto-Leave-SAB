-- Helper: Format time displays
local function formatTime(seconds)
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = seconds % 60
    return string.format("%02d:%02d:%02d", h, m, s)
end

-- Helper: Simulate activity to reset AFK timer
local function simulateActivity()
    pcall(function()
        VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        task.wait(0.1)
        VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
    end)
end

-- Event handler for player becoming idle
local function onAfk()
    afkCount = afkCount + 1
    countLabel.Text = "AFK დაცვა: " .. afkCount .. "-ჯერ"
    
    statusLabel.Text = "სტატუსი: მოქმედება!"
    statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    
