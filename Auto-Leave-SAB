-- ==========================================
-- 1. Game Initialization & Loading Failsafes
-- ==========================================
while not game:IsLoaded() or game.PlaceId == 0 do
    task.wait(0.5)
end

-- Target Game Identifiers (Steal a Brainrot & subgames)
local TARGET_PLACE_ID = 109983668079237
local TARGET_UNIVERSE_ID = 7709344486

-- Verify if we are in the target game or its subgames
if game.PlaceId ~= TARGET_PLACE_ID and game.GameId ~= TARGET_UNIVERSE_ID then
    return -- Terminate script immediately
end

local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local localPlayer = Players.LocalPlayer

-- Wait for the LocalPlayer object to exist
while not localPlayer do
    task.wait(0.5)
    localPlayer = Players.LocalPlayer
end

-- CRITICAL: Wait for the Character and HumanoidRootPart to fully load.
-- This ensures the network replication connection is fully active, 
-- preventing the Kick command from failing silently on the loading screen.
local character = localPlayer.Character
while not character or not character:FindFirstChild("HumanoidRootPart") do
    task.wait(0.5)
    character = localPlayer.Character
end

-- Safely locate PlayerGui instead of CoreGui to avoid detection
local PlayerGui = localPlayer:WaitForChild("PlayerGui")
local isDisconnecting = false

-- ==========================================
-- 2. Kick & Player Detection Logic (Multi-Layered)
-- ==========================================

-- Thread-safe disconnect function with dynamic player name insertion
local function disconnect(triggerPlayerName)
    if isDisconnecting then return end
    isDisconnecting = true
    
    local targetName = triggerPlayerName or "Someone"
    
    -- Formats the message dynamically with the triggering player's name
    pcall(function()
        localPlayer:Kick("Scammer Alert! " .. targetName .. " is popular scammer!\n- Sammy")
    end)
end

-- Scan the player list for anyone other than the local player
local function scanServer()
    local currentPlayers = Players:GetPlayers()
    for _, player in ipairs(currentPlayers) do
        if player ~= localPlayer then
            disconnect(player.Name)
            return true
        end
    end
    return false
end

-- Layer 1: Standard player connection listener
Players.PlayerAdded:Connect(function(player)
    if player ~= localPlayer then
        disconnect(player.Name)
    end
end)

-- Layer 2: Low-level engine hierarchy listener (fallback for event failures)
Players.ChildAdded:Connect(function(child)
    if child:IsA("Player") and child ~= localPlayer then
        disconnect(child.Name)
    end
end)

-- Layer 3: Optimized background polling loop (AFK safety net)
task.spawn(function()
    while not isDisconnecting do
        scanServer()
        task.wait(0.5)
    end
end)

-- Run an immediate check on startup (now safe since the character is spawned)
scanServer()

