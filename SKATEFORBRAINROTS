local PreviousSeconds = 9999
local GracePeriodEnd = 0 

task.spawn(function()
    while task.wait(1) do
        -- IF ANOTHER SCRIPT WAS EXECUTED AFTER THIS ONE, KILL THIS LOOP
        if getgenv and getgenv().SmileB_ExecutionID ~= ScriptExecutionID then break end

        -- 1. Read the Timer
        local rawText = GetTimer()
        TimerText.Text = "Timer: " .. rawText
        local totalSeconds = ParseTime(rawText)

        -- 2. "THE SPAWN LOCK"
        if PreviousSeconds <= 20 and totalSeconds > 500 then
            GracePeriodEnd = os.time() + 15
        end

        if rawText ~= "Loading..." then
            PreviousSeconds = totalSeconds
        end

        -- 3. Try to Grab Items
        if FindBestTarget() then
            if Settings.AutoHop then
                StatusText.Text = "Status: Grabbed! Hopping in 10s..."
                task.wait(10)
                SaveServerData(600)
                SmartServerHop()
                task.wait(10)
            else
                StatusText.Text = "Status: Grabbed! (AutoHop OFF)"
                task.wait(5)
            end
            continue
        end

        -- 4. Hopping Logic
        if rawText == "Loading..." then
            StatusText.Text = "Status: Finding UI..."
        elseif os.time() < GracePeriodEnd then
            StatusText.Text = "Status: Game dropping item! Waiting..."
        elseif totalSeconds > Settings.HopThreshold and Settings.AutoHop then
            StatusText.Text = "Status: Time > 150s, Scanning..."
            task.wait(1)
            if FindBestTarget() then continue end
            
            SaveServerData(totalSeconds)
            SmartServerHop()
            task.wait(10)
        else
            StatusText.Text = "Status: Waiting for spawn..."
        end
    end
end)
