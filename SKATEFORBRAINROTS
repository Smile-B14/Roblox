-- 7. ZERO-LAG ITEM SCANNER
-----------------------------------------
local PriorityList = {Divine = 3, Celestial = 2, Secret = 1}
local RarityCache = {}

local function FindBestTarget()
    local requiredFolder = Workspace:FindFirstChild("Required")
    local brainrotsFolder = requiredFolder and requiredFolder:FindFirstChild("Brainrots")
    if not brainrotsFolder then return false end

    local BestTarget = nil
    local HighestPriority = 0

    for _, model in ipairs(brainrotsFolder:GetChildren()) do
        local prompt = model:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            local identifiedRarity = RarityCache[model] 
            
            if not identifiedRarity then
                local modelPos = model:GetPivot().Position
                for rarityName, padPos in pairs(PadCache) do
                    if (modelPos - padPos).Magnitude < 45 then
                        identifiedRarity = rarityName; break
                    end
                end
                
                if not identifiedRarity then
                    local modelText = string.lower((prompt.ActionText or "") .. " " .. (prompt.ObjectText or ""))
                    for _, desc in ipairs(model:GetDescendants()) do
                        if desc:IsA("TextLabel") or desc:IsA("TextBox") then
                            modelText = modelText .. " " .. string.lower(desc.Text)
                        end
                    end
                    
                    if string.find(modelText, "divine") then identifiedRarity = "Divine"
                    elseif string.find(modelText, "celestial") then identifiedRarity = "Celestial"
                    elseif string.find(modelText, "secret") then identifiedRarity = "Secret"
                    else identifiedRarity = "None" end
                end
                
                RarityCache[model] = identifiedRarity
            end

            if identifiedRarity and identifiedRarity ~= "None" and Settings[identifiedRarity] then
                local prio = PriorityList[identifiedRarity]
                if prio > HighestPriority then
                    HighestPriority = prio
                    BestTarget = {Prompt = prompt, Model = model, Rarity = identifiedRarity}
                end
            end
        end
    end
    
    for model, _ in pairs(RarityCache) do
        if not model.Parent then RarityCache[model] = nil end
    end

    if BestTarget then
        StatusText.Text = "Status: Grabbing " .. BestTarget.Rarity .. "!"
        GrabItem(BestTarget.Prompt, BestTarget.Model)
        return true
    end
    return false
end

