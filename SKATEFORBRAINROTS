local ExpectedEndTime_OG = 0
local ExpectedEndTime_Secret = 0

local LastValidSync_OG = os.time()

local function ParseTime(timeStr)
    if type(timeStr) ~= "string" then return -1 end
    
    if string.find(string.upper(timeStr), "N/A") then return -1 end
    
    local h, m, s = timeStr:match("(%d+):(%d+):(%d+)")
    if h and m and s then return (tonumber(h) * 3600) + (tonumber(m) * 60) + tonumber(s) end
    
    local min, sec = timeStr:match("(%d+):(%d+)")
    if min and sec then return (tonumber(min) * 60) + tonumber(sec) end
    
    local min2 = timeStr:match("(%d+)m") or 0
    local sec2 = timeStr:match("(%d+)s") or 0
    if tonumber(min2) == 0 and tonumber(sec2) == 0 and not timeStr:match("%d") then return -1 end
    return (tonumber(min2) * 60) + tonumber(sec2)
end

