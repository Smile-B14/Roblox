local function FetchServersSafely(PlaceID)
    local url = "https://games.roblox.com/v1/games/" .. tostring(PlaceID) .. "/servers/Public?sortOrder=Asc&limit=100"
    local ReqFunc = request or http_request or (syn and syn.request)
    
    if ReqFunc then
        local success, response = pcall(function() return ReqFunc({Url = url, Method = "GET"}) end)
        if success and response and response.StatusCode == 200 then
            local decoded = HttpService:JSONDecode(response.Body)
            if decoded then return decoded end
        end
    end
    
    local success, response = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
    if success and response then return response end
    
    return nil
end

local function SmartServerHop()
    if not Settings.AutoHop then return end
    local PlaceID = game.PlaceId
    local servers = LoadServers()
    
    local BestServer = nil
    local SmallestWait = math.huge
    
    local visited = getgenv and getgenv().SmileB_VisitedServers or {}
    local currentTime = os.time()
    
    for id, stamp in pairs(servers) do
        local isOnCooldown = visited[id] and currentTime < visited[id]
        if id ~= game.JobId and not isOnCooldown then
            local waitTime = stamp - currentTime
            if waitTime > 10 and waitTime <= Settings.HopThreshold then
                if waitTime < SmallestWait then
                    SmallestWait = waitTime
                    BestServer = id
                end
            end
        end
    end
    
    if BestServer then
        StatusText.Text = "Status: Sniping Known Server..."
        task.wait(1)
        TeleportService:TeleportToPlaceInstance(PlaceID, BestServer, LocalPlayer)
        task.wait(5)
    end
    
    StatusText.Text = "Status: Scouting New Servers..."
    local response = FetchServersSafely(PlaceID)
    
    if response and response.data then
        local valid = {}
        for _, srv in ipairs(response.data) do
            if type(srv) == "table" and srv.playing and srv.maxPlayers then
                local isOnCooldown = visited[srv.id] and currentTime < visited[srv.id]
                if srv.playing < srv.maxPlayers and srv.playing > 0 and srv.id ~= game.JobId then
                    if not isOnCooldown then
                        table.insert(valid, srv.id)
                    end
                end
            end
        end
        
        if #valid == 0 and getgenv then
            getgenv().SmileB_VisitedServers = {[game.JobId] = os.time() + 60}
        elseif #valid > 0 then
            TeleportService:TeleportToPlaceInstance(PlaceID, valid[math.random(1, #valid)], LocalPlayer)
            task.wait(5)
            return
        end
    end
    
    TeleportService:Teleport(PlaceID, LocalPlayer)
end

