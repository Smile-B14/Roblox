local function GrabTarget(prompt, targetModel, returnCFrame)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local targetPos = targetModel:GetPivot()
    if targetModel:IsA("BasePart") then targetPos = targetModel.CFrame end

    if prompt then pcall(function() prompt.HoldDuration = 0 end) end
    
    hrp.AssemblyLinearVelocity = Vector3.zero 

    -- 1. TELEPORT TO ITEM & AGGRESSIVE SPAM
    for i = 1, 15 do
        hrp.CFrame = targetPos * CFrame.new(0, 0.5, 0) 
        if type(fireproximityprompt) == "function" then 
            pcall(function()
                fireproximityprompt(prompt, 1)
                fireproximityprompt(prompt, 0)
            end)
        end
        pcall(function() prompt:InputHoldBegin() end)
        task.wait(0.04) 
        pcall(function() prompt:InputHoldEnd() end)
    end
    
    -- 2. FORCE TELEPORT BACK TO BASE IMMEDIATELY
    hrp.CFrame = returnCFrame
    hrp.AssemblyLinearVelocity = Vector3.zero
    task.wait(0.2) 
    
    -- 3. POLL FOR INVENTORY ITEM AT BASE (Fixes network delay)
    local tool = nil
    for w = 1, 30 do -- Wait up to 3 seconds for server to give item
        tool = char:FindFirstChildWhichIsA("Tool") or LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool")
        if tool then break end
        task.wait(0.1)
    end

    if not tool then return false end

    -- 4. VERIFY NOT LUCKY BLOCK
    local toolName = string.lower(tool.Name)
    for _, desc in ipairs(tool:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextBox") then
            toolName = toolName .. " " .. string.lower(tostring(desc.Text or ""))
        end
    end
    
    if string.find(toolName, "lucky block") then
        task.wait(0.2)
        ForceDropTool()
        return false 
    end
    
    -- 5. SECURELY DROP ITEM ON THE PLOT
    task.wait(0.3)
    ForceDropTool()
    task.wait(0.5) 
    
    return true
end

local function FindAndGrabTargets(isOGDropImminent)
    local requiredFolder = Workspace:FindFirstChild("Required")
    local brainrotsFolder = requiredFolder and requiredFolder:FindFirstChild("Brainrots")
    if not brainrotsFolder then return false, {} end

    local ValidTargets = {}

    for _, model in ipairs(brainrotsFolder:GetChildren()) do
        if IgnoredModels[model] then continue end

        local prompt = model:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            local rawText = string.lower((prompt.ActionText or "") .. " " .. (prompt.ObjectText or ""))
            for _, desc in ipairs(model:GetDescendants()) do
                if desc:IsA("TextLabel") or desc:IsA("TextBox") then
                    rawText = rawText .. " " .. string.lower(tostring(desc.Text or ""))
                end
            end

            if string.find(rawText, "lucky block") then
                IgnoredModels[model] = true
                continue
            end

            local modelPos = model:GetPivot().Position
            local padRarity = "None"
            
            for rarityName, padPos in pairs(PadCache) do
                if (modelPos - padPos).Magnitude < 100 then
                    padRarity = rarityName; break
                end
            end
            
            if padRarity == "None" then
                if string.find(rawText, "divine") then padRarity = "Divine"
                elseif string.find(rawText, "celestial") then padRarity = "Celestial"
                elseif string.find(rawText, "secret") then padRarity = "Secret"
                elseif string.match(rawText, "%f[%a]og%f[%A]") then padRarity = "OG"
                end
            end

            if padRarity == "Secret" and isOGDropImminent then continue end
            
            local score = CalculateScore(rawText, padRarity)
            
            if score == 0 then
                IgnoredModels[model] = true
            else
                table.insert(ValidTargets, {Prompt = prompt, Model = model, Rarity = padRarity, Score = score})
            end
        end
    end

    if #ValidTargets == 0 then 
        for model, _ in pairs(IgnoredModels) do
            if not model.Parent then IgnoredModels[model] = nil end
        end
        return false, {} 
    end

    table.sort(ValidTargets, function(a, b) return a.Score > b.Score end)

    local grabbedRarities = {}
    local successfullyGrabbedAnything = false

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local PreSequenceCFrame = hrp and hrp.CFrame or SavedBaseCFrame

    for _, target in ipairs(ValidTargets) do
        if target.Model and target.Model.Parent then
            local grabbed = GrabTarget(target.Prompt, target.Model, PreSequenceCFrame)
            if grabbed then
                successfullyGrabbedAnything = true
                table.insert(grabbedRarities, target.Rarity)
                
                SessionStats.Grabs = SessionStats.Grabs + 1
                if target.Rarity == "OG" then SessionStats.OG = SessionStats.OG + 1
                elseif target.Rarity == "Divine" then SessionStats.Divine = SessionStats.Divine + 1
                elseif target.Rarity == "Celestial" then SessionStats.Celestial = SessionStats.Celestial + 1
                elseif target.Rarity == "Secret" then SessionStats.Secret = SessionStats.Secret + 1
                end
            end
        end
    end
    
    if successfullyGrabbedAnything then
        SaveStats()
        if hrp then
            hrp.CFrame = PreSequenceCFrame
            hrp.AssemblyLinearVelocity = Vector3.zero
        end
        return true, grabbedRarities
    end
    
    return false, {}
end

-----------------------------------------
-- 10. TIMER MAIN LOOP (OG ONLY)
-----------------------------------------
local PrevOG = 9999
local GracePeriodEnd = 0 
local ServerStartTime = os.time() 

local LastDrawnOG = -1
local LastDrawnSec = -1

task.spawn(function()
    while task.wait(0.05) do
        if type(getgenv) == "function" and getgenv().SmileB_ExecutionID ~= ScriptExecutionID then break end

        if os.time() - ServerStartTime >= 240 and Settings.AutoHop then
            SmartServerHop()
            task.wait(5)
            continue
        end

        local ogSecs = ExpectedEndTime_OG > 0 and math.max(0, ExpectedEndTime_OG - os.time()) or -1
        local secSecs = ExpectedEndTime_Secret > 0 and math.max(0, ExpectedEndTime_Secret - os.time()) or -1

        if ogSecs >= 0 then
            if ogSecs ~= LastDrawnOG then
                OGTimerOverlay.Text = string.format("OG: %dm %ds", math.floor(ogSecs / 60), ogSecs % 60)
                LastDrawnOG = ogSecs
            end
        else
            if LastDrawnOG ~= -2 then
                OGTimerOverlay.Text = "OG: Syncing..."
                LastDrawnOG = -2
            end
        end

        if secSecs >= 0 then
            if secSecs ~= LastDrawnSec then
                SecretTimerOverlay.Text = string.format("Secret: %dm %ds", math.floor(secSecs / 60), secSecs % 60)
                LastDrawnSec = secSecs
            end
        else
            if LastDrawnSec ~= -2 then
                SecretTimerOverlay.Text = "Secret: Syncing..."
                LastDrawnSec = -2
            end
        end

        if (PrevOG <= 20 and ogSecs > 500) then
            GracePeriodEnd = os.time() + 15
        end
        PrevOG = ogSecs

        local isOGDropImminent = (ogSecs >= 0 and ogSecs <= 30)
        
        -- Always check and grab targets first regardless of timers
        local grabbedAnything, grabbedRarities = FindAndGrabTargets(isOGDropImminent)
        
        if grabbedAnything then
            local shouldHop = false
            for _, rarity in ipairs(grabbedRarities) do
                if rarity == "OG" or rarity == "Divine" or rarity == "Celestial" then
                    shouldHop = true
                    break
                end
            end

            if shouldHop and Settings.AutoHop then
                task.wait(5)
                local saveTime = ogSecs > 0 and ogSecs or 600
                SaveTimerData(saveTime)
                SmartServerHop()
            else
                task.wait(2)
            end
            continue
        end

        -- SYNCING FAILSAFE: ONLY care about OG timer. If OG fails to load for 20 seconds, hop.
        local isStale_OG = (os.time() - LastValidSync_OG > 20)

        if isStale_OG and Settings.AutoHop then
            if not isOGDropImminent then
                if os.time() - ServerStartTime > 6 then
                    SmartServerHop()
                    task.wait(5)
                    continue
                end
            end
        end
        
        if os.time() < GracePeriodEnd then continue end
        
        -----------------------------------------
        -- STRICT WAIT-THEN-HOP LOGIC (OG ONLY)
        -----------------------------------------
        local timeInServer = os.time() - ServerStartTime
        local validOG = (ogSecs >= 0)
        local ogWantsHop = (not validOG) or (ogSecs > Settings.HopThreshold)
        
        if timeInServer > 8 then
            if validOG then
                if ogWantsHop and Settings.AutoHop then
                    local saveTime = ogSecs > 0 and ogSecs or 600
                    SaveTimerData(saveTime)
                    SmartServerHop()
                    task.wait(5)
                end
            else
                if timeInServer > 25 and Settings.AutoHop then
                    SmartServerHop()
                    task.wait(5)
                end
            end
        end
    end
end)
