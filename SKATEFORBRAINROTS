-- 4. THE SMART SNIPER HOPPER
-----------------------------------------
local function SmartServerHop()
    if not Settings.AutoHop then return end
    local PlaceID = game.PlaceId
    local servers = LoadServers()
    
    local BestServer = nil
    local SmallestWait = math.huge
    
    for id, stamp in pairs(servers) do
        if id ~= game.JobId then
            local waitTime = stamp - os.time()
            if waitTime > 15 and waitTime <= Settings.HopThreshold then
                if waitTime < SmallestWait then
                    SmallestWait = waitTime
                    BestServer = id
                end
            end
        end
    end
    
    if BestServer then
        StatusText.Text = "Status: Sniping Known Server..."
        task.wait(1)
        TeleportService:TeleportToPlaceInstance(PlaceID, BestServer, LocalPlayer)
        task.wait(10)
    end
    
    StatusText.Text = "Status: Scouting New Servers..."
    local success, response = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceID .. "/servers/Public?sortOrder=Desc&limit=100"))
    end)
    
    if success and response and response.data then
        local valid = {}
        for _, srv in ipairs(response.data) do
            if type(srv) == "table" and srv.playing and srv.maxPlayers then
                if srv.playing < srv.maxPlayers and srv.playing > 0 and srv.id ~= game.JobId then
                    if not servers[srv.id] then
                        table.insert(valid, srv.id)
                    end
                end
            end
        end
        if #valid > 0 then
            TeleportService:TeleportToPlaceInstance(PlaceID, valid[math.random(1, #valid)], LocalPlayer)
            task.wait(10)
        end
    end
    
    TeleportService:Teleport(PlaceID, LocalPlayer)
end

