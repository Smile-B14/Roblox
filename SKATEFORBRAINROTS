local TimerFileName = "SmileB_ServerTimers.json"

local function LoadTimers()
    if isfile and readfile and isfile(TimerFileName) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(TimerFileName)) end)
        if success and type(data) == "table" then return data end
    end
    return {}
end

local function SaveTimerData(remainingSeconds)
    if not writefile then return end
    local servers = LoadTimers()
    if remainingSeconds then servers[game.JobId] = os.time() + remainingSeconds end
    local cleanedData = {}
    for id, stamp in pairs(servers) do
        if os.time() < stamp + 60 then cleanedData[id] = stamp end
    end
    pcall(function() writefile(TimerFileName, HttpService:JSONEncode(cleanedData)) end)
end

local ExpectedEndTime = 0
local CachedTimerUI = nil

local function ParseTime(timeStr)
    if type(timeStr) ~= "string" then return 0 end
    local min = timeStr:match("(%d+)m") or 0
    local sec = timeStr:match("(%d+)s") or 0
    if min == 0 and sec == 0 and not timeStr:match("%d") then return 0 end
    return (tonumber(min) * 60) + tonumber(sec)
end

