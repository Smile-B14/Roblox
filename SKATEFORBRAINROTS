local FileName = "SmileB_ServerTimers.json"

local function LoadServers()
    if isfile and readfile and isfile(FileName) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(FileName)) end)
        if success and type(data) == "table" then return data end
    end
    return {}
end

local function SaveServerData(remainingSeconds)
    if not writefile then return end
    local servers = LoadServers()
    
    if remainingSeconds then
        servers[game.JobId] = os.time() + remainingSeconds
    end
    
    local cleanedData = {}
    for id, stamp in pairs(servers) do
        if os.time() < stamp + 60 then
            cleanedData[id] = stamp
        end
    end
    
    pcall(function() writefile(FileName, HttpService:JSONEncode(cleanedData)) end)
end

