-----------------------------------------
local function GrabAndVerify(prompt, targetModel)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local targetPos = targetModel:GetPivot()
    if targetModel:IsA("BasePart") then targetPos = targetModel.CFrame end

    -- Remove ProximityPrompt wait completely
    if prompt then pcall(function() prompt.HoldDuration = 0 end) end
    
    -- Halt Character to prevent over-flinging past object
    hrp.AssemblyLinearVelocity = Vector3.zero 

    -- Rapid Instant Grab 
    for i = 1, 4 do
        hrp.CFrame = targetPos * CFrame.new(0, 0.5, 0) 
        if fireproximityprompt then 
            fireproximityprompt(prompt, 1)
            fireproximityprompt(prompt, 0)
        end
        prompt:InputHoldBegin()
        task.wait(0.02)
        prompt:InputHoldEnd()
    end
    
    task.wait(0.3) -- Verification Speed Improved

    local tool = char:FindFirstChildWhichIsA("Tool") or LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool")
    if not tool then
        hrp.CFrame = TargetBaseCFrame
        return
    end

    local toolName = string.lower(tool.Name)
    for _, desc in ipairs(tool:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextBox") then
            toolName = toolName .. " " .. string.lower(desc.Text)
        end
    end
    
    if string.find(toolName, "lucky block") then
        hrp.CFrame = TargetBaseCFrame
        task.wait(0.2)
        ClickDropButton()
        return
    end
    
    hrp.CFrame = TargetBaseCFrame
end

local function FindBestTarget(isMainDropImminent)
    local requiredFolder = Workspace:FindFirstChild("Required")
    local brainrotsFolder = requiredFolder and requiredFolder:FindFirstChild("Brainrots")
    if not brainrotsFolder then return false, nil end

    local BestTarget = nil
    local HighestPriority = 0

    for _, model in ipairs(brainrotsFolder:GetChildren()) do
        if IgnoredModels[model] then continue end

        local prompt = model:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            local rawText = string.lower((prompt.ActionText or "") .. " " .. (prompt.ObjectText or ""))
            for _, desc in ipairs(model:GetDescendants()) do
                if desc:IsA("TextLabel") or desc:IsA("TextBox") then
                    rawText = rawText .. " " .. string.lower(desc.Text)
                end
            end

            if string.find(rawText, "lucky block") then
                IgnoredModels[model] = true
                continue
            end

            local modelPos = model:GetPivot().Position
            local padRarity = "None"
            
            for rarityName, padPos in pairs(PadCache) do
                if (modelPos - padPos).Magnitude < 100 then
                    padRarity = rarityName; break
                end
            end
            
            if padRarity == "None" then
                if string.find(rawText, "divine") then padRarity = "Divine"
                elseif string.find(rawText, "celestial") then padRarity = "Celestial"
                elseif string.find(rawText, "secret") then padRarity = "Secret"
                end
            end

            if padRarity == "Secret" and isMainDropImminent then continue end
            
            local score = CalculateScore(rawText, padRarity)
            
            if score == 0 then
                IgnoredModels[model] = true
            elseif score > HighestPriority then
                HighestPriority = score
                BestTarget = {Prompt = prompt, Model = model, Rarity = padRarity}
            end
        end
    end

    if BestTarget then
        GrabAndVerify(BestTarget.Prompt, BestTarget.Model)
        
        -- INCREMENT AND SAVE CROSS-SERVER STATS
        SessionStats.Grabs = SessionStats.Grabs + 1
        if BestTarget.Rarity == "Divine" then SessionStats.Divine = SessionStats.Divine + 1
        elseif BestTarget.Rarity == "Celestial" then SessionStats.Celestial = SessionStats.Celestial + 1
        elseif BestTarget.Rarity == "Secret" then SessionStats.Secret = SessionStats.Secret + 1
        end
        SaveStats()
        
        return true, BestTarget.Rarity
    end
    
    for model, _ in pairs(IgnoredModels) do
        if not model.Parent then IgnoredModels[model] = nil end
    end
    
    return false, nil
end

