local IgnoredModels = {} 

local function CalculateScore(text, padRarity)
    local isRad = string.find(text, "radioactive")
    local isDia = string.find(text, "diamond")
    local isGold = string.find(text, "gold")
    local isNormal = not (isRad or isDia or isGold)
    
    local hasSpecificName = false
    if Settings.SpecificNames ~= "" then
        local names = string.split(Settings.SpecificNames, ",")
        for _, n in ipairs(names) do
            local cleanName = string.lower(string.match(n, "^%s*(.-)%s*$") or n)
            if cleanName ~= "" and string.find(text, cleanName) then
                hasSpecificName = true; break
            end
        end
    end
    
    local isValid = false
    
    if padRarity == "OG" and Settings.OG then
        if isRad and Settings.OG_Rad then isValid = true end
        if isDia and Settings.OG_Dia then isValid = true end
        if isGold and Settings.OG_Gold then isValid = true end
        if isNormal and Settings.OG_Norm then isValid = true end
    elseif padRarity == "Celestial" and Settings.Celestial then
        if hasSpecificName then isValid = true end
    elseif padRarity == "Secret" and Settings.Secret then
        if hasSpecificName then isValid = true end
    elseif padRarity == "Divine" and Settings.Divine then
        if isRad and Settings.Divine_Rad then isValid = true end
        if isDia and Settings.Divine_Dia then isValid = true end
        if isGold and Settings.Divine_Gold then isValid = true end
        if isNormal and Settings.Divine_Norm then isValid = true end
    end
    
    if not isValid then return 0 end
    
    local mutScore = 0
    if isRad then mutScore = 40
    elseif isDia then mutScore = 30
    elseif isGold then mutScore = 20
    end
    
    -- PRIORITY ENFORCED: OG (1000) > Divine (500) > Celestial (300) > Secret (100)
    local rarityScore = 0
    if padRarity == "OG" then rarityScore = 1000
    elseif padRarity == "Divine" then rarityScore = 500
    elseif padRarity == "Celestial" then rarityScore = 300
    elseif padRarity == "Secret" then rarityScore = 100
    end
    
    return rarityScore + mutScore
end

