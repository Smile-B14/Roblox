local PadCache = {}
task.spawn(function()
    local pads = Workspace:WaitForChild("Pads", 10)
    if pads then
        for _, rarity in ipairs({"Divine", "Celestial", "Secret"}) do
            local pad = pads:FindFirstChild(rarity)
            if pad then
                if pad:IsA("Model") then
                    -- Get absolute mathematical center of the model
                    local cframe, size = pad:GetBoundingBox()
                    PadCache[rarity] = cframe.Position
                elseif pad:IsA("BasePart") then
                    PadCache[rarity] = pad.Position
                end
            end
        end
    end
end)

local CachedTimerUI = nil
local function GetTimer()
    if CachedTimerUI and CachedTimerUI.Parent then return CachedTimerUI.Text end
    local mainGui = LocalPlayer.PlayerGui:FindFirstChild("MainGui")
    local frames = mainGui and mainGui:FindFirstChild("Frames")
    if frames then
        for _, v in pairs(frames:GetDescendants()) do
            if v:IsA("TextLabel") and (v.Name == "Countdown" or v.Name == "CountDown") then
                CachedTimerUI = v; return v.Text
            end
        end
    end
    return "Loading..."
end

local function ParseTime(timeStr)
    if type(timeStr) ~= "string" then return 0 end
    local min = timeStr:match("(%d+)m") or 0
    local sec = timeStr:match("(%d+)s") or 0
    if min == 0 and sec == 0 and not timeStr:match("%d") then return 0 end
    return (tonumber(min) * 60) + tonumber(sec)
end

