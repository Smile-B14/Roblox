-- 10. MAIN LOOP
-----------------------------------------
local PreviousSeconds = 9999
local GracePeriodEnd = 0 
local ServerStartTime = os.time() 
local LastDrawnSecond = -1

task.spawn(function()
    while task.wait(0.05) do
        if getgenv and getgenv().SmileB_ExecutionID ~= ScriptExecutionID then break end

        if os.time() - ServerStartTime >= 240 and Settings.AutoHop then
            SmartServerHop()
            task.wait(5)
            continue
        end

        local totalSeconds = 0
        if ExpectedEndTime > 0 then
            totalSeconds = math.max(0, ExpectedEndTime - os.time())
            
            if totalSeconds ~= LastDrawnSecond then
                if totalSeconds > 0 then
                    TimerOverlay.Text = string.format("%dm %ds", math.floor(totalSeconds / 60), totalSeconds % 60)
                else
                    TimerOverlay.Text = "0m 0s"
                end
                LastDrawnSecond = totalSeconds
            end
        else
            if LastDrawnSecond ~= -2 then
                TimerOverlay.Text = "Syncing Time..."
                LastDrawnSecond = -2
            end
        end

        if PreviousSeconds <= 20 and totalSeconds > 500 then
            GracePeriodEnd = os.time() + 15
        end
        PreviousSeconds = totalSeconds

        local isMainDropImminent = (ExpectedEndTime > 0 and totalSeconds <= 30)
        local targetGrabbed, rarityGrabbed = FindBestTarget(isMainDropImminent)
        
        if targetGrabbed then
            if rarityGrabbed == "Divine" or rarityGrabbed == "Celestial" then
                if Settings.AutoHop then
                    task.wait(1.5)
                    SaveTimerData(600)
                    SmartServerHop()
                else
                    task.wait(2)
                end
            else
                task.wait(2)
            end
            continue
        end

        if ExpectedEndTime == 0 then
            -- Init
        elseif os.time() < GracePeriodEnd then
            -- Wait for Physical Drop
        elseif totalSeconds > Settings.HopThreshold and Settings.AutoHop then
            if FindBestTarget(isMainDropImminent) then continue end
            SaveTimerData(totalSeconds)
            SmartServerHop()
            task.wait(5) 
        end
    end
end)
