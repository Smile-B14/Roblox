-- =========================================
-- UTILITIES
-- =========================================
local function IsTeammate(Player)
    if not Player or Player == LocalPlayer then return false end
    local myTeamID = LocalPlayer:GetAttribute("TeamID")
    local theirTeamID = Player:GetAttribute("TeamID")
    if myTeamID ~= nil and theirTeamID ~= nil then
        return myTeamID == theirTeamID
    end
    if LocalPlayer.Team ~= nil and Player.Team ~= nil then
        return LocalPlayer.Team == Player.Team
    end
    return false
end

local function GetESPFolder(Camera)
    local folder = Camera:FindFirstChild("SmileESP_Folder")
    if not folder then
        folder = Instance.new("Folder")
        folder.Name = "SmileESP_Folder"
        folder.Parent = Camera
    end
    return folder
end

-- =========================================
-- FULLBRIGHT LOGIC
-- =========================================
local wasFullbright = false
local OrigAmbient, OrigBrightness, OrigClockTime, OrigFogEnd, OrigGlobalShadows
local fbColor = Color3.fromRGB(255, 255, 255)

local function UpdateFullbright()
    if shared.Fullbright then
        if not wasFullbright then
            OrigAmbient = Lighting.Ambient
            OrigBrightness = Lighting.Brightness
            OrigClockTime = Lighting.ClockTime
            OrigFogEnd = Lighting.FogEnd
            OrigGlobalShadows = Lighting.GlobalShadows
            wasFullbright = true
        end
        if Lighting.Ambient ~= fbColor then Lighting.Ambient = fbColor end
        if Lighting.Brightness ~= 2 then Lighting.Brightness = 2 end
        if Lighting.ClockTime ~= 14 then Lighting.ClockTime = 14 end
        if Lighting.FogEnd ~= 100000 then Lighting.FogEnd = 100000 end
        if Lighting.GlobalShadows ~= false then Lighting.GlobalShadows = false end
    else
        if wasFullbright then
            Lighting.Ambient = OrigAmbient
            Lighting.Brightness = OrigBrightness
            Lighting.ClockTime = OrigClockTime
            Lighting.FogEnd = OrigFogEnd
            Lighting.GlobalShadows = OrigGlobalShadows
            wasFullbright = false
        end
    end
end

-- =========================================
-- OPTIMIZED ESP SYSTEM
-- =========================================
local espObjects = {}

local function CreateESP(Player, Camera)
    local espFolder = GetESPFolder(Camera)
    
    local Chams = Instance.new("Highlight")
    Chams.Name = Player.Name
    Chams.Parent = espFolder
    Chams.FillTransparency = 0.5
    Chams.OutlineTransparency = 0
    Chams.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    
    local HpBar = Instance.new("BillboardGui")
    HpBar.Name = Player.Name.."_HP"
    HpBar.Parent = espFolder
    HpBar.AlwaysOnTop = true
    HpBar.Size = UDim2.new(0.15, 0, 4.5, 0)
    HpBar.StudsOffset = Vector3.new(-1.8, 0, 0)
    
    local bg = Instance.new("Frame", HpBar)
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(0,0,0)
    bg.BorderSizePixel = 0
    
    local bar = Instance.new("Frame", bg)
    bar.Size = UDim2.new(1, 0, 1, 0)
    bar.BackgroundColor3 = Color3.fromRGB(0,255,0)
    bar.BorderSizePixel = 0

    return {
        Chams = Chams,
        HpBar = HpBar,
        Bar = bar,
        LastHealth = -1,
        LastTeamState = nil
    }
end

Players.PlayerRemoving:Connect(function(Player)
    if espObjects[Player] then
        espObjects[Player].Chams:Destroy()
        espObjects[Player].HpBar:Destroy()
        espObjects[Player] = nil
    end
end)

local function UpdateESP(Camera)
    if not shared.ESPEnabled then
        for _, objs in pairs(espObjects) do
            if objs.Chams.Enabled then objs.Chams.Enabled = false end
            if objs.HpBar.Enabled then objs.HpBar.Enabled = false end
        end
        return
    end

    for _, Player in ipairs(Players:GetPlayers()) do
        if Player == LocalPlayer then continue end
        
        local char = Player.Character
        local humanoid = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local isAlive = humanoid and humanoid.Health > 0
        local isTeammate = IsTeammate(Player)
        
        local objs = espObjects[Player]
        if not objs or objs.Chams.Parent ~= GetESPFolder(Camera) then
            if objs then pcall(function() objs.Chams:Destroy() objs.HpBar:Destroy() end) end
            objs = CreateESP(Player, Camera)
            espObjects[Player] = objs
        end

        if not char or not isAlive or (shared.ESPTeamCheck and isTeammate) then
            if objs.Chams.Enabled then objs.Chams.Enabled = false end
            if objs.HpBar.Enabled then objs.HpBar.Enabled = false end
            continue
        end

        if not objs.Chams.Enabled then objs.Chams.Enabled = true end
        if not objs.HpBar.Enabled then objs.HpBar.Enabled = true end

        if objs.Chams.Adornee ~= char then objs.Chams.Adornee = char end
        if objs.HpBar.Adornee ~= hrp then objs.HpBar.Adornee = hrp end

        if objs.LastTeamState ~= isTeammate then
            objs.LastTeamState = isTeammate
            local col = isTeammate and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
            objs.Chams.FillColor = col
            objs.Chams.OutlineColor = col
        end

        local curHealth = humanoid.Health
        if objs.LastHealth ~= curHealth then
            objs.LastHealth = curHealth
            local healthPct = math.clamp(curHealth / humanoid.MaxHealth, 0, 1)
            objs.Bar.Size = UDim2.new(1, 0, healthPct, 0)
            objs.Bar.Position = UDim2.new(0, 0, 1 - healthPct, 0)
            
            if healthPct > 0.6 then objs.Bar.BackgroundColor3 = Color3.fromRGB(0,255,0)
            elseif healthPct > 0.3 then objs.Bar.BackgroundColor3 = Color3.fromRGB(255,255,0)
            else objs.Bar.BackgroundColor3 = Color3.fromRGB(255,0,0) end
        end
    end
end

