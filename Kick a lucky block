local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local TeleportService = game:GetService("TeleportService")
local GuiService = game:GetService("GuiService")
local player = Players.LocalPlayer

-- 1. Invisible X2 Clicker
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            local upg = player.PlayerGui:FindFirstChild("KickUpgrades")
            if not upg then return end
            
            for _, v in ipairs(upg:GetChildren()) do
                if v.Name == "Bonus" and v:IsA("ImageButton") and v.Visible and v.AbsolutePosition.X > 0 then
                    if getconnections then
                        for _, conn in ipairs(getconnections(v.MouseButton1Click)) do
                            pcall(function() conn:Fire() end)
                            pcall(function() conn.Function() end)
                        end
                        for _, conn in ipairs(getconnections(v.Activated)) do
                            pcall(function() conn:Fire() end)
                            pcall(function() conn.Function() end)
                        end
                    end
                    v.Visible = false 
                    task.wait(1.5)
                    break
                end
            end
        end)
    end
end)

-- 2. Active Anti-AFK (Clicks every 5 seconds)
task.spawn(function()
    while task.wait(5) do
        pcall(function()
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new())
        end)
    end
end)

player.Idled:Connect(function()
    pcall(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
end)

-- 3. Auto-Rejoin
GuiService.ErrorMessageChanged:Connect(function()
    task.wait(3)
    pcall(function()
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    end)
    task.wait(2)
    pcall(function()
        TeleportService:Teleport(game.PlaceId, player)
    end)
end)
