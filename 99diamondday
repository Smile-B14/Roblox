local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer
local username = player.Name:gsub("%s+", ""):lower()

-- GitHub raw URL to your JSON whitelist
local whitelistUrl = "https://raw.githubusercontent.com/Smile-B14/Roblox/main/whitelist.json"

local function kick(message)
    player:Kick(message)
end

-- Returns current Tbilisi time (UTC+4) in total minutes of the day
local function getTbilisiMinutes()
    local tbilisiTimeTable = os.date("!*t", os.time() + 14400)
    return tbilisiTimeTable.hour * 60 + tbilisiTimeTable.min
end

-- Function to fetch and validate whitelist from GitHub
local function checkWhitelist()
    -- Append timestamp parameter (?nocache=...) to prevent Roblox from caching old JSON data
    local success, rawData = pcall(function()
        return game:HttpGet(whitelistUrl .. "?nocache=" .. os.time())
    end)

    if not success then
        return false, "შეცდომა: სერვერთან დაკავშირება ვერ მოხერხდა."
    end

    local decodeSuccess, whitelist = pcall(function()
        return HttpService:JSONDecode(rawData)
    end)

    if not decodeSuccess or type(whitelist) ~= "table" then
        return false, "შეცდომა: whitelist მონაცემები დაზიანებულია."
    end

    -- Find matching user
    local expireTime = nil
    for savedName, savedTime in pairs(whitelist) do
        if tostring(savedName):gsub("%s+", ""):lower() == username then
            expireTime = tostring(savedTime)
            break
        end
    end

    if not expireTime then
        return false, "წვდომა არ გაქვს."
    end

    -- Parse HH:MM format
    local hour, minute = expireTime:match("^(%d+):(%d+)$")
    if not hour or not minute then
        return false, "შეცდომა: დროის ფორმატი არასწორია."
    end

    hour = tonumber(hour)
    minute = tonumber(minute)

    if hour > 23 or minute > 59 then
        return false, "შეცდომა: დრო არასწორია."
    end

    local expireMinutes = hour * 60 + minute
    local currentTbilisiMinutes = getTbilisiMinutes()

    -- Expiration check
    if currentTbilisiMinutes >= expireMinutes then
        return false, "წვდომის დრო ამოიწურა."
    end

    return true, nil
end

-- ==========================================
-- 1. Initial Check
-- ==========================================
local allowed, kickReason = checkWhitelist()
if not allowed then
    kick(kickReason)
    return
end

-- ==========================================
-- 2. Start Background Monitor Loop FIRST
-- ==========================================
task.spawn(function()
    while task.wait(5) do -- Checks every 5 seconds
        local stillAllowed, reason = checkWhitelist()
        if not stillAllowed then
            kick(reason)
            break
        end
    end
end)

-- ==========================================
-- 3. Load and Run Main Script
-- ==========================================
print("Access granted for " .. player.Name .. ". Starting script...")
loadstring(game:HttpGet("https://raw.githubusercontent.com/caomod2077/Script/main/FNDayFarm.lua"))()
