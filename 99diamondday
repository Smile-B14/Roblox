local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local username = player.Name:gsub("%s+", ""):lower()
local whitelistUrl = "https://raw.githubusercontent.com/Smile-B14/Roblox/main/whitelist.json"

local expireUnixTime = 0
local isInitialized = false

local function kick(message)
    player:Kick(message)
end

local gui = Instance.new("ScreenGui")
gui.Name = "WhitelistTimer"
local successGui = pcall(function() gui.Parent = CoreGui end)
if not successGui then gui.Parent = player:WaitForChild("PlayerGui") end

local textLabel = Instance.new("TextLabel", gui)
textLabel.Size = UDim2.new(0, 180, 0, 30)
textLabel.Position = UDim2.new(0, 10, 0, 10)
textLabel.BackgroundColor3 = Color3.new(0, 0, 0)
textLabel.BackgroundTransparency = 0.5
textLabel.TextColor3 = Color3.new(1, 1, 1)
textLabel.TextScaled = true
textLabel.Visible = false
textLabel.Text = "იტვირთება..."

player.Chatted:Connect(function(msg)
    if msg:lower() == "/time" then
        textLabel.Visible = not textLabel.Visible
    end
end)

local function fetchLatestWhitelist()
    local cacheUrl = whitelistUrl .. "?v=" .. tostring(os.time()) .. tostring(math.random(1000, 9999))
    local req = (syn and syn.request) or (http and http.request) or request or http_request
    
    if req then
        local success, response = pcall(function()
            return req({
                Url = cacheUrl,
                Method = "GET",
                Headers = {
                    ["Cache-Control"] = "no-cache, no-store, must-revalidate",
                    ["Pragma"] = "no-cache",
                    ["Expires"] = "0"
                }
            })
        end)
        if success and type(response) == "table" and response.Success then
            return response.Body
        end
    end
    return game:HttpGetAsync(cacheUrl, true)
end

local function fetchAndUpdateTime()
    local success, rawData = pcall(fetchLatestWhitelist)
    if not success or type(rawData) ~= "string" or rawData == "" then return false, "network" end

    local decodeSuccess, whitelist = pcall(function() return HttpService:JSONDecode(rawData) end)
    if not decodeSuccess or type(whitelist) ~= "table" then return false, "format" end

    local expireTimeStr = nil
    for savedName, savedTime in pairs(whitelist) do
        if tostring(savedName):gsub("%s+", ""):lower() == username then
            expireTimeStr = tostring(savedTime)
            break
        end
    end

    if not expireTimeStr then return false, "removed" end

    local day, month, year, hour, minute = expireTimeStr:match("^(%d+)[-%./](%d+)[-%./](%d+)%s+(%d+):(%d+)$")
    if not day then return false, "format" end

    local expireUtc = os.time({
        year = tonumber(year), 
        month = tonumber(month), 
        day = tonumber(day), 
        hour = tonumber(hour), 
        min = tonumber(minute), 
        sec = 0
    }) - 14400
    
    expireUnixTime = expireUtc
    isInitialized = true

    return true, nil
end

task.spawn(function()
    local attempts = 0
    while not isInitialized and attempts < 5 do
        local ok = fetchAndUpdateTime()
        if ok then break end
        attempts = attempts + 1
        task.wait(2)
    end
    if not isInitialized then
        kick("შეცდომა: სერვერთან კავშირი ვერ დამყარდა.")
    end
end)

task.spawn(function()
    while task.wait(10) do
        local ok, err = fetchAndUpdateTime()
        if not ok and err == "removed" then
            kick("შენი სახელი წაიშალა სიიდან ან დრო ამოიწურა.")
            break
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if expireUnixTime == 0 then return end

    local currentUtc = os.time()
    local timeLeft = expireUnixTime - currentUtc

    if timeLeft <= 0 then
        kick("წვდომის დრო ამოიწურა.")
        return
    end

    if textLabel.Visible then
        local hours = math.floor(timeLeft / 3600)
        local mins = math.floor((timeLeft % 3600) / 60)
        local secs = timeLeft % 60
        textLabel.Text = string.format("დრო: %02d:%02d:%02d", hours, mins, secs)
    end
end)

print("Access granted for " .. player.Name .. ". Starting script...")
task.spawn(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/caomod2077/Script/main/FNDayFarm.lua"))()
end)
