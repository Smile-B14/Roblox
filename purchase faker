-- Anti-Kick Protection Hook (Safe namecall structure to prevent core thread locks)
task.spawn(function()
    local hookSuccess, hook = pcall(function()
        return hookmetamethod or (X_Hookmetamethod or nil)
    end)
    
    if hookSuccess and hook then
        local oldNamecall
        oldNamecall = hook(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            if self and typeof(self) == "Instance" and typeof(method) == "string" then
                if self == LocalPlayer and (method == "Kick" or method == "kick") then
                    warn("[Faker] Prevented server/local attempt to kick client.")
                    return nil
                end
            end
            return oldNamecall(self, ...)
        end)
    end
end)

