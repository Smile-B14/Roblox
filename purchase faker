local function scanGame()
    for _, item in ipairs(scannerTabFrame:GetChildren()) do
        if item:IsA("Frame") and item.Name ~= "ScanControlHeader" then
            item:Destroy()
        end
    end
    
    local foundItems = {}
    local function registerItem(name, id, itemType)
        local idNum = tonumber(id)
        if not idNum or idNum <= 0 then return end
        local key = itemType .. "_" .. tostring(idNum)
        if not foundItems[key] then
            foundItems[key] = {Name = name, ID = idNum, Type = itemType}
        end
    end

    local targets = {}
    pcall(function() table.insert(targets, LocalPlayer:WaitForChild("PlayerGui", 2)) end)
    pcall(function() table.insert(targets, game:GetService("Workspace")) end)
    pcall(function() table.insert(targets, game:GetService("ReplicatedStorage")) end)

    for _, target in ipairs(targets) do
        if not target then continue end
        pcall(function()
            for _, desc in ipairs(target:GetDescendants()) do
                pcall(function()
                    local attrs = desc:GetAttributes()
                    for attrName, attrVal in pairs(attrs) do
                        if type(attrVal) == "number" then
                            local lowerName = string.lower(attrName)
                            if string.find(lowerName, "product") or string.find(lowerName, "devproduct") then
                                registerItem(desc.Name, attrVal, "Product")
                            elseif string.find(lowerName, "gamepass") or string.find(lowerName, "passid") or string.find(lowerName, "pass") then
                                registerItem(desc.Name, attrVal, "Gamepass")
                            end
                        end
                    end
                end)

                pcall(function()
                    if desc:IsA("IntValue") or desc:IsA("NumberValue") then
                        local lowerName = string.lower(desc.Name)
                        if string.find(lowerName, "productid") or string.find(lowerName, "devproduct") then
                            registerItem(desc.Parent.Name .. " [" .. desc.Name .. "]", desc.Value, "Product")
                        elseif string.find(lowerName, "gamepass") or string.find(lowerName, "passid") then
                            registerItem(desc.Parent.Name .. " [" .. desc.Name .. "]", desc.Value, "Gamepass")
                        end
                    end
                end)
                
                pcall(function()
                    if desc:IsA("GuiButton") then
                        local idVal = desc:FindFirstChild("ID") or desc:FindFirstChild("Id")
                        if idVal and (idVal:IsA("IntValue") or idVal:IsA("NumberValue")) then
                            registerItem(desc.Name, idVal.Value, "Product/Gamepass")
                        end
                    end
                end)
            end
        end)
    end
    
    local count = 0
    for _, item in pairs(foundItems) do
        count = count + 1
        createScannerLog(item.Name, item.ID, item.Type)
    end
    
    if count == 0 then
        createNoItemsLog()
    end
end

